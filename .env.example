# ---------------------------------------------------------------------------
# SB-Optima — Local development environment variables
# ---------------------------------------------------------------------------
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# The Docker Compose setup reads .env automatically.
# Streamlit (run locally) also uses SB_OPTIMA_BACKEND_URL.
# ---------------------------------------------------------------------------

# -- Backend URL (used by Streamlit to reach the FastAPI backend) --
SB_OPTIMA_BACKEND_URL=http://localhost:8000

# -- Apply safety gate (set to "true" only when you intend to push prices) --
SB_OPTIMA_ENABLE_APPLY=false

# -- Postgres (used inside Docker network; change host to localhost for local) --
DATABASE_URL=postgresql+psycopg2://sboptima:sboptima@postgres:5432/sboptima

# -- Redis (used inside Docker network; change host to localhost for local) --
REDIS_URL=redis://redis:6379/0

# -- Optional: OpenAI API key (for LLM-assisted features) --
# OPENAI_API_KEY=sk-...

# -- Optional: DanDomain SOAP credentials (not baked into images) --
# DANDOMAIN_API_USERNAME=
# DANDOMAIN_API_PASSWORD=
