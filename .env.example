# ---------------------------------------------------------------------------
# SB-Optima — Local development environment variables
# ---------------------------------------------------------------------------
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# The Docker Compose setup reads .env automatically.
# Streamlit (run locally) also uses SB_OPTIMA_BACKEND_URL.
# ---------------------------------------------------------------------------

# -- Environment tag (dev | staging | prod) --
SBOPTIMA_ENV=dev

# -- Backend URL (used by Streamlit to reach the FastAPI backend) --
SB_OPTIMA_BACKEND_URL=http://localhost:8000

# -- Apply safety gate (set to "true" only when you intend to push prices) --
SB_OPTIMA_ENABLE_APPLY=false

# -- Postgres (used inside Docker network; change host to localhost for local) --
DATABASE_URL=postgresql+psycopg2://sboptima:sboptima@postgres:5432/sboptima
POSTGRES_USER=sboptima
POSTGRES_PASSWORD=sboptima
POSTGRES_DB=sboptima

# -- Redis (used inside Docker network; change host to localhost for local) --
REDIS_URL=redis://redis:6379/0

# -- Job result TTL in seconds (default 3600 = 1 hour) --
# JOB_RESULT_TTL_S=3600

# -- Product cache (Task 3.2) --
# PRODUCT_CACHE_TTL_S=900
# CACHE_KEY_SALT=change-me
# CACHE_MAX_PAYLOAD_KB=5120

# -- SOAP rate limiting (Task 3.3) --
# SOAP_MAX_CONCURRENT=3
# SOAP_CALL_DELAY_S=0.2
# SOAP_RATE_LIMIT_PER_S=5.0

# -- CORS allowed origins (comma-separated; leave empty to disable CORS) --
# CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# -- Optional: OpenAI API key (for LLM-assisted features) --
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=

# -- Optional: DanDomain SOAP credentials (not baked into images) --
# DANDOMAIN_API_USERNAME=
# DANDOMAIN_API_PASSWORD=

# -- Optional: encryption / auth secrets (future tasks) --
# ENCRYPTION_KEY=
# CREDENTIAL_CIPHER=fernet
# ALLOW_REQUEST_CREDENTIALS_WHEN_AUTHED=false
# JWT_SECRET=
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXP_MINUTES=60
# SBOPTIMA_AUTH_REQUIRED=false
