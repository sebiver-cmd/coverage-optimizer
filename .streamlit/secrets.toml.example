# DanDomain API credentials for the Coverage Optimizer.
#
# Copy this file to  .streamlit/secrets.toml  and fill in your real
# values.  The secrets.toml file is git-ignored and will never be
# committed to the repository.
#
# You can find your API key in your DanDomain admin panel under:
#   Settings → Integration → API
#
# See https://support.dandomain.dk/webshop-hjaelp/api/api-documentation/

[dandomain]
shop_url   = "https://YOUR-SHOP.webshop.dandomain.dk"
api_key    = "YOUR_API_KEY_HERE"
api_method = "rest"   # Only "rest" (API v1) is supported; GraphQL does not yet cover product data
site_id    = 1
