# DanDomain API credentials for the Coverage Optimizer.
#
# Copy this file to  .streamlit/secrets.toml  and fill in your real
# values.  The secrets.toml file is git-ignored and will never be
# committed to the repository.
#
# The app uses the HostedShop SOAP API.
# Enable it in your DanDomain admin under Settings → API: SOAP,
# then create an API employee under Settings → Employees.
#
# See https://webshop-help.dandomain.dk/integration-via-api/

[dandomain]
username = "api-user@example.com"
password = "YOUR_API_PASSWORD_HERE"
site_id  = 1
